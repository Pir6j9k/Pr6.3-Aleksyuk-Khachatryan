<Page x:Class="ISIP323_Khachatryan_WPF.Pages.BookingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookingPage">
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Ваш заказ" FontSize="28" FontWeight="Bold" Margin="10" Foreground="White"/>
            <Border BorderBrush="Blue" BorderThickness="1" Padding="10" Margin="10">
                <StackPanel>
                    <TextBlock x:Name="TxtMovieTitle" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Foreground="White" Margin="5"/>
                    <TextBlock x:Name="TxtDateTime" FontSize="16" TextWrapping="Wrap" Foreground="White" Margin="5"/>
                    <TextBlock x:Name="TxtHall" FontSize="16" TextWrapping="Wrap" Foreground="White" Margin="5"/>
                </StackPanel>
            </Border>
            <Button Content="Назад к выбору мест" Click="BtnBack_Click"
                    Background="Blue" BorderThickness="0" Foreground="White" 
                    FontSize="16" FontWeight="Bold" Height="40" Width="300" Margin="10,185,10,10"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Билеты" FontSize="28" FontWeight="Bold" Margin="10" Foreground="White" TextAlignment="Center"/>

            <ListView x:Name="LViewSeats" Height="250" Background="Black" BorderThickness="0" Margin="10" Foreground="White">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Ряд" DisplayMemberBinding="{Binding RowNumber}" Width="50"/>
                        <GridViewColumn Header="Место" DisplayMemberBinding="{Binding SeatNumber}" Width="50"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <TextBlock Text="К оплате: " FontSize="20" Foreground="White"/>
                <TextBlock x:Name="TxtTotalPrice" Text="0 руб" FontSize="20" FontWeight="Bold" Foreground="White"/>
            </StackPanel>

            <Button Content="ОПЛАТИТЬ И ЗАБРОНИРОВАТЬ" Click="BtnConfirm_Click" 
                    Background="Blue" Foreground="White" FontWeight="Bold" FontSize="16" 
                    Height="40" Width="300" Margin="10" BorderThickness="0"/>

        </StackPanel>
    </Grid>
</Page>
