<Page x:Class="ISIP323_Khachatryan_WPF.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="608.285" d:DesignWidth="800"
      Title="RegisterPage">

    <Grid Background="Black"> 
        <Border Background="Black" 
                VerticalAlignment="Center" HorizontalAlignment="Center" Width="300"
                BorderBrush="Blue" BorderThickness="3">

            <StackPanel Margin="20">
                <TextBlock Text="Регистрация"  FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="5"/>

                <Label Content="Имя:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <TextBox x:Name="TxtName" Height="25" VerticalContentAlignment="Center" Margin="5,0,5,5"/>

                <Label Content="Фамилия:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <TextBox x:Name="TxtLastName" Height="25"  VerticalContentAlignment="Center" Margin="5,0,5,0"/>

                <Label Content="Логин:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <TextBox x:Name="TxtLogin" Height="25"  VerticalContentAlignment="Center" Margin="5,0,5,0"/>

                <Label Content="Пароль" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <PasswordBox x:Name="PBoxPass" Height="25"  VerticalContentAlignment="Center" Margin="5,0,5,0"/>

                <Label Content="Повторите пароль" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <PasswordBox x:Name="PBoxPassConfirm" Height="25" VerticalContentAlignment="Center" Margin="5,0,5,0"/>

                <Button Content="Зарегистрироваться" Height="30" Background="Blue" Foreground="White" 
                        FontWeight="Bold" Click="BtnReg_Click" Margin="5,10,5,5" BorderThickness="0"/>

                <Button Content="Отмена" Background="Blue" FontWeight="Bold" Margin="5,5,5,10"
                        Foreground="White" BorderThickness="0" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
