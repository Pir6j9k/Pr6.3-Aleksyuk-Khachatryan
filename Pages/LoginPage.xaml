<Page x:Class="ISIP323_Khachatryan_WPF.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="Black">
        <Border VerticalAlignment="Center" Background="Black" HorizontalAlignment="Center" Width="300" BorderBrush="blue" BorderThickness="3">

            <StackPanel Margin="20">
                <TextBlock Text="Aвторизация"  FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"  Foreground="White" Margin="10"/>

                <Label Content="Логин:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5"/>
                <TextBox x:Name="TxtLogin" Height="30" Margin="5,0,5,5" VerticalContentAlignment="Center"/>

                <Label Content="Пароль" FontWeight="Bold" FontSize="16" Foreground="White" Margin="5,0,5,0"/>
                <PasswordBox x:Name="PBoxPassword" Height="30" Margin="5,0,5,5" VerticalContentAlignment="Center"/>

                <Button Content="Войти" Height="30" Background="Blue" Foreground="White" FontWeight="Bold" 
                        Click="BtnLogin_Click" FontSize="14" Margin="5" BorderThickness="0"/>

                <Button Content="Нет аккаунта? Зарегистрироваться" Margin="5"
                        Background="Transparent" BorderThickness="0" Foreground="Red" 
                        Cursor="Hand" Click="BtnReg_Click"/>

                <Button Content="Назад на главную" Margin="5" 
                        Background="Transparent" BorderThickness="0" Foreground="White" 
                        Click="BtnBack_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
