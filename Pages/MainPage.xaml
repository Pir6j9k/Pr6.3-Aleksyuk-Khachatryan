<Page x:Class="ISIP323_Khachatryan_WPF.Pages.MainPage"
      Loaded="Page_Loaded"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="637.064" d:DesignWidth="800"
      Title="MainPage">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <Label Content="Поиск" Background="Blue" VerticalAlignment="Center" Foreground="White" 
                   FontSize="14" FontWeight="Bold" FontFamily="Arial Black" Margin="5"/>
            <TextBox x:Name="TxtSearch" Width="200" Margin="5" VerticalAlignment="Center" TextChanged="TxtSearch_TextChanged"/>

            <Label Content="Сортировка:" VerticalAlignment="Center" Margin="5" Background="Blue" 
                   Foreground="White" FontSize="14" FontWeight="Bold" FontFamily="Arial Black"/>
            <ComboBox x:Name="CmbSort" Width="150" Margin="5" VerticalAlignment="Center" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="По названию (А-Я)"/>
                <ComboBoxItem Content="По рейтингу (высокий)"/>
            </ComboBox>

            <Button x:Name="BtnLogin" Content="Регистрация / Вход" Margin="5" Padding="5" Background="Blue" BorderThickness="0"
                    Foreground="White" FontSize="14" FontWeight="Bold" FontFamily="Arial Black" Click="BtnLogin_Click"/>
        </StackPanel>

        <ListView x:Name="LViewMovies" Grid.Row="1" 
                  Margin="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  BorderThickness="0" Background="Black" MouseDoubleClick="LViewMovies_MouseDoubleClick">
        
        <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="3" BorderBrush="Blue" Margin="10" Width="220" Height="434" Background="Black">
                        <StackPanel>
                            <Image Source="{Binding ImagePath}" Width="200" Height="300" Stretch="UniformToFill" Margin="5"/>

                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Background="Blue" 
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="5"  Foreground="WhiteSmoke"/>

                            <TextBlock Text="{Binding GenreString}" FontSize="12"  Foreground="WhiteSmoke" FontWeight="Bold"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="5" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Рейтинг"  Foreground="WhiteSmoke" Margin="5" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Rating}" FontWeight="Bold"  Foreground="WhiteSmoke" Margin="5"/>
                                    <TextBlock Text="{Binding AgeRating}" Foreground="Red" FontWeight="Bold" Margin="5"/>
                                </StackPanel>

                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                <TextBlock Text="{Binding StartDate, StringFormat=В кино с: dd.MM.yyyy}" FontWeight="Bold" FontSize="12"  Foreground="WhiteSmoke"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
