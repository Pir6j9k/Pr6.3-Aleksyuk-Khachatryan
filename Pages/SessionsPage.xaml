<Page x:Class="ISIP323_Khachatryan_WPF.Pages.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SessionsPage">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock x:Name="TxtMovieTitle" Text="Название фильма" FontSize="24" FontWeight="Bold" Foreground="White" Margin="5"/>
            <TextBlock x:Name="TxtSessionInfo" FontSize="16" Foreground="White" Text="Дата и время | Зал" Margin="5"/>
            <TextBlock Text="ЭКРАН" FontSize="20" HorizontalAlignment="Center" Margin="10" FontWeight="Bold" Background="Blue" Width="630" TextAlignment="Center" Foreground="White"/>
        </StackPanel>

        <Viewbox Grid.Row="1" Margin="20">
            <UniformGrid x:Name="UniGridSeats"/>
        </Viewbox>

        <Border Grid.Row="2" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel VerticalAlignment="Center" Margin="10">
                    <TextBlock Text="Выбрано мест: 0" x:Name="TxtSelectedCount" FontSize="14" Foreground="White" Margin="5"/>
                    <TextBlock Text="Итого: 0 руб." x:Name="TxtTotalPrice" FontSize="14" FontWeight="Bold" Foreground="White" Margin="5"/>
                </StackPanel>

                <Button Content="Купить билеты" Click="BtnBuy_Click" 
                        Background="Blue" Foreground="White" 
                        FontSize="16" FontWeight="Bold"  BorderThickness="0"
                        Height="50" Margin="5" Padding="5"/>

                <Button Content="Отмена" Click="BtnBack_Click" 
                        Margin="5" Padding="5" Height="50" 
                        FontSize="16" FontWeight="Bold" BorderThickness="0"
                        Background="Blue" Foreground="White" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
