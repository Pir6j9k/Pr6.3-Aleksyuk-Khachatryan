<Page x:Class="ISIP323_Khachatryan_WPF.Pages.MoviePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP323_Khachatryan_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MoviePage">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image  x:Name="ImgMoviePoster" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="10" Stretch="Uniform" VerticalAlignment="Top"/>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10">
            <TextBlock x:Name="TxtTitle" FontSize="30" FontWeight="Bold" Margin="10"  TextWrapping="Wrap" Foreground="White"/>

            <TextBlock x:Name="TxtGenres" FontSize="16" Foreground="White" Margin="10"/>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Рейтинг" FontWeight="Bold" Foreground="White" Margin="5"/>
                <TextBlock x:Name="TxtRating" Foreground="White" Margin="5"/>

                <TextBlock Text="Длительность: " FontWeight="Bold" Foreground="White" Margin="5"/>
                <TextBlock x:Name="TxtDuration" Foreground="White" Margin="5"/>
                <TextBlock Text=" мин." Foreground="White" Margin="5"/>
            </StackPanel>

            <TextBlock Text="Описание:" FontWeight="Bold" Margin="10" Foreground="White"/>
            <TextBlock x:Name="TxtDescription" TextWrapping="Wrap" FontSize="14" Margin="10,5,10,5" Foreground="White"/>

            <Separator/>
            <TextBlock Text="Расписание сеансов:" FontSize="16" FontWeight="Bold" Margin="10,5,10,5" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="GridSessions" Grid.Row="1" Grid.Column="1" Margin="10,0,10,0" BorderThickness="0"
                  AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="GridSessions_MouseDoubleClick" Background="Black">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding DateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="*" />
                <DataGridTextColumn Header="Зал" Binding="{Binding Halls.Name}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:N0} руб.'}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Назад к списку фильмов" Grid.Row="2" Grid.ColumnSpan="2" 
                Width="200" Height="40" Margin="10" BorderThickness="0"
                Click="BtnBack_Click" Background="Blue" 
                Foreground="White" FontWeight="Bold"/>
    </Grid>
</Page>
